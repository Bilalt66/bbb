<?php

$servername = "localhost";
$username = "root";
$password = "";
$dbname = "mijn_database";

try {
    $conn = new PDO("mysql:host=$servername;dbname=$dbname", $username, $password);
    $conn->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

    echo "Connected successfully<br><br>";
} catch (PDOException $e) {
    die("Connection failed: " . $e->getMessage());
}


if (isset($_POST['add'])) {

    $stmt = $conn->prepare("
        INSERT INTO producten (naam, prijs)
        VALUES (:naam, :prijs)
    ");

    $stmt->execute([
        ':naam' => $_POST['naam'],
        ':prijs' => $_POST['prijs']
    ]);

    echo "Product succesvol toegevoegd.<br><br>";
}


if (isset($_GET['del'])) {
    $conn->exec("DELETE FROM producten WHERE id=$_GET[del]");
}


if (isset($_POST['upd'])) {
    $conn->exec("
        UPDATE producten 
        SET naam='$_POST[naam]', prijs='$_POST[prijs]' 
        WHERE id=$_POST[id]
    ");
}


$q = $conn->query("SELECT * FROM producten");
?>

