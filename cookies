<?php
if (isset($_POST['naam']) && !empty($_POST['naam'])) {
    $naam = htmlspecialchars($_POST['naam']);

    setcookie("naam", $naam, time() + 3600);

    header("Location: " . $_SERVER['PHP_SELF']);
    exit;
}
?>

